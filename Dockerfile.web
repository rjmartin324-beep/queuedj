FROM node:20-alpine AS builder

WORKDIR /app

# Copy everything needed for the Expo web build
COPY packages/shared-types ./packages/shared-types
COPY apps/mobile ./apps/mobile

# Pre-link @queuedj/shared-types so npm finds it locally instead of fetching from registry
RUN mkdir -p apps/mobile/node_modules/@queuedj && \
    ln -sf /app/packages/shared-types apps/mobile/node_modules/@queuedj/shared-types

WORKDIR /app/apps/mobile
RUN npm install --legacy-peer-deps
RUN npx expo export -p web

FROM node:20-alpine
RUN npm install -g serve
COPY --from=builder /app/apps/mobile/dist /dist
EXPOSE 3000
CMD ["serve", "/dist", "-p", "3000"]
