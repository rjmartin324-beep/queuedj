FROM node:20-alpine

WORKDIR /app

# Copy workspace root manifests for npm workspaces
COPY package.json package-lock.json* ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY services/api/package.json ./services/api/

RUN npm install --workspace=@queuedj/api --workspace=@queuedj/shared-types --include=dev

# Copy source (volumes override in dev, but needed for initial build)
COPY packages/shared-types ./packages/shared-types
COPY services/api/src ./services/api/src

EXPOSE 3001

CMD ["npx", "tsx", "watch", "/app/services/api/src/index.ts"]
