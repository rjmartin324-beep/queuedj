{
  "expo": {
    "name": "PartyGlue",
    "slug": "partyglue",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "partyglue",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.partyglue.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.partyglue.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-camera",
        {
          "cameraPermission": "PartyGlue uses the camera to scan room QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "realtimeUrl": "http://localhost:3002",
      "apiUrl": "http://localhost:3001",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "695234c7-d52b-4bfb-a477-872822e96c84"
      }
    },
    "owner": "verymurt"
  }
}
