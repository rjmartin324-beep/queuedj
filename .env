# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=queuedj
POSTGRES_PASSWORD=queuedj_dev
POSTGRES_DB=queuedj
DATABASE_URL=postgres://queuedj:queuedj_dev@localhost:5432/queuedj

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Services ─────────────────────────────────────────────────────────────────
API_PORT=3001
REALTIME_PORT=3002
ML_PORT=8000

# ─── Public URLs (set these when using ngrok or a real host) ──────────────────
# For local dev with real phones:
#   1. ngrok http 3001  →  copy https URL → EXPO_PUBLIC_API_URL
#   2. ngrok http 3002  →  copy https URL → EXPO_PUBLIC_REALTIME_URL
#   3. Restart Expo: npx expo start --clear
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_REALTIME_URL=http://localhost:3002

# ─── Auth / Rooms ─────────────────────────────────────────────────────────────
# Secret used to sign host tokens (JWT-like but lightweight)
HOST_TOKEN_SECRET=queuedj_dev_secret_key_32chars_ok
# How long a room stays alive with no active connections (seconds)
ROOM_TTL_SECONDS=14400

# ─── Spotify OAuth ────────────────────────────────────────────────────────────
# PKCE flow — read-only metadata only. Never used for playback.
SPOTIFY_CLIENT_ID=a057d52ad95643ecbbab163fc220e9ee
SPOTIFY_CLIENT_SECRET=f2821db2460143fab1ceafd640dafec9
SPOTIFY_REDIRECT_URI=queuedj://auth/spotify/callback

# ─── Apple Music ──────────────────────────────────────────────────────────────
APPLE_MUSIC_TEAM_ID=your_apple_team_id
APPLE_MUSIC_KEY_ID=your_musickit_key_id
APPLE_MUSIC_PRIVATE_KEY_PATH=./certs/apple_musickit.p8

# ─── AcoustID (ISRC fingerprinting) ──────────────────────────────────────────
# Free API key from acoustid.org — 3 req/sec on free tier
ACOUSTID_API_KEY=IRBYGmU3BY

# ─── ReccoBeats (audio features: tempo/energy/danceability/valence) ──────────
# Get key at reccobeats.com — free tier: 1000 req/day
RECCOBEATS_API_KEY=your_reccobeats_api_key

# ─── Last.fm (similar tracks) ─────────────────────────────────────────────────
# Free API key at last.fm/api
LASTFM_API_KEY=your_lastfm_api_key

# ─── TheAudioDB (genre/mood/bio/images) ───────────────────────────────────────
# Free tier uses API key "1" — premium at theaudiodb.com
THEAUDIODB_API_KEY=1

# ─── MusicBrainz ──────────────────────────────────────────────────────────────
# Set a descriptive user agent — required by MusicBrainz ToS
MUSICBRAINZ_USER_AGENT=QueueDJ/0.1.0 (contact@queuedj.com)

# ─── Push Notifications (Expo Push) ──────────────────────────────────────────
# Expo handles FCM + APNs routing. Use Expo push tokens.
EXPO_ACCESS_TOKEN=kugJpljxMsOpXwh9LQ4LDkbgdp7xsGT5U7yaKCsN
# Firebase Server Key — only needed for direct FCM (bypassing Expo Push)
# Found in Firebase Console → Project Settings → Cloud Messaging → Server key
FCM_SERVER_KEY=your_firebase_server_key

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ROOM_CREATE=5          # per hour per IP
RATE_LIMIT_QUEUE_INJECT=10        # per minute per guest
RATE_LIMIT_VOTE=1                 # per second per guest

# ─── Audio / Playback ─────────────────────────────────────────────────────────
# Max look-ahead buffer per deck in seconds
# Memory: 2 decks × 30s × 44100Hz × 4 bytes × 2ch ≈ 42MB (stereo, no stems)
# With 4 stems: ≈ 85MB. Profile on low-end devices before shipping stems.
LOOKAHEAD_BUFFER_SECONDS=30

# ─── ML / AI ──────────────────────────────────────────────────────────────────
# BullMQ job TTL (ms) before a job is considered failed
ML_JOB_TTL_MS=30000
# How many RLHF signals to accumulate before triggering a model retrain
RLHF_RETRAIN_THRESHOLD=10000

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Toggle features without redeploying
FEATURE_STEM_SEPARATION=false     # Phase 5 — off until server-side pipeline is ready
FEATURE_HAPTIC_SYNC=false         # Phase 5 — off until latency is validated
FEATURE_GENERATIVE_BRIDGE=false   # Phase 7 — off until server-rendered pipeline ready
FEATURE_DISTRIBUTED_COMPUTE=false # Phase 6 — off until edge compute is implemented
FEATURE_RLHF_LOGGING=false        # Phase 4 — off until ToS + legal review complete

# ─── Legal / Compliance ───────────────────────────────────────────────────────
# Data retention period for anonymized session signals (days)
RLHF_DATA_RETENTION_DAYS=90
# Enable GDPR-compliant data minimization mode
GDPR_MODE=true
