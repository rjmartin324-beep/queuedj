{
  "expo": {
    "name": "PartyGlue",
    "slug": "queuedj",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "queuedj",
    "userInterfaceStyle": "dark",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a000f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.partyglue.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.partyglue.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "PartyGlue",
      "shortName": "PartyGlue",
      "title": "PartyGlue"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "privacyManifests": {
              "NSPrivacyAccessedAPITypes": [
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                  "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
                  "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
                  "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
                  "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
                }
              ]
            }
          }
        }
      ],
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7c3aed",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PartyGlue uses the camera to scan QR codes and take photos for party games."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PartyGlue accesses your photos for party game photo challenges.",
          "cameraPermission": "PartyGlue uses the camera for party game photo challenges."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "realtimeUrl": "http://localhost:3002",
      "apiUrl": "http://localhost:3001",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "695234c7-d52b-4bfb-a477-872822e96c84"
      }
    },
    "owner": "verymurt"
  }
}
